   "source": [
    "# Content-Based Course Recommendation\n",
    "\n",
    "This notebook builds a recommender using TF-IDF on course titles and cosine similarity."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "import pandas as pd\n",
    "from sklearn.feature_extraction.text import TfidfVectorizer\n",
    "from sklearn.metrics.pairwise import linear_kernel\n",
    "\n",
    "# Load dataset\n",
    "courses = pd.read_csv(\"../data/udemy_course_data.csv\")\n",
    "\n",
    "# Preprocess\n",
    "courses[\"course_title\"] = courses[\"course_title\"].str.lower()\n",
    "\n",
    "# TF-IDF\n",
    "tfidf = TfidfVectorizer(stop_words=\"english\")\n",
    "tfidf_matrix = tfidf.fit_transform(courses[\"course_title\"])\n",
    "\n",
    "# Cosine similarity\n",
    "cosine_sim = linear_kernel(tfidf_matrix, tfidf_matrix)\n",
    "\n",
    "def recommend_course(idx, top_n=5):\n",
    "    sim_scores = list(enumerate(cosine_sim[idx]))\n",
    "    sim_scores = sorted(sim_scores, key=lambda x: x[1], reverse=True)\n",
    "    return [courses.iloc[i[0]][\"course_title\"] for i in sim_scores[1:top_n+1]]\n",
    "\n",
    "# Example: recommend courses similar to index 10\n",
    "recommend_course(10)"
   ]
  }
 ],
